# Folo 导出工具配置
# 复制此文件为 .env.export 并填入你的真实配置

# 你的认证 Token（从浏览器 Cookie 中获取，参见 README）
FOLO_SESSION_TOKEN=your_session_token_here

# API 地址（默认：https://api.follow.is）
FOLO_API_URL=https://api.follow.is

# 输出目录（默认：./unread-articles）
FOLO_OUTPUT_DIR=./unread-articles

# 每次请求的文章数量（默认：100）
FOLO_LIMIT=100

# 并发处理工作线程数（默认：5）
FOLO_CONCURRENCY=16

# AI 辅助过滤与阅读所需的 API 配置
AI_API_URL=https://api.siliconflow.cn/v1
AI_API_KEY=your_api_key_here
AI_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# LLM 并发请求数（默认：64）
LLM_CONCURRENCY=64

# 去重配置
DEDUP_STRATEGY=jaccard
DEDUP_THRESHOLD=0.7
DEDUP_NGRAM_SIZE=2
